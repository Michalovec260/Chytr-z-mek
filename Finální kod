#include <Keypad.h>

const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {16, 17, 18, 19};
byte colPins[COLS] = {21, 22, 23, 27};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

#define RELAY_PIN 13
#define GREEN_LED 25
#define RED_LED 26

String correctCode = "5";
String enteredCode = "";

void setup() {
  Serial.begin(115200);
  Serial.println("START");

  pinMode(RELAY_PIN, OUTPUT);
  pinMode(GREEN_LED, OUTPUT);
  pinMode(RED_LED, OUTPUT);

  digitalWrite(RELAY_PIN, HIGH);
  digitalWrite(GREEN_LED, LOW);
  digitalWrite(RED_LED, LOW);
}

void loop() {
  char key = keypad.getKey();

  if (key) {
    Serial.println(key);

    if (key == '*') {
      enteredCode = "";
    }
    else if (key == '#') {
      if (enteredCode == correctCode) {
        unlock();
      } else {
        wrongCode();
      }

      enteredCode = "";
    }
    else {
      enteredCode += key;
    }
  }
}

void unlock() {
  digitalWrite(GREEN_LED, HIGH);
  digitalWrite(RELAY_PIN, LOW);

  delay(3000);

  digitalWrite(RELAY_PIN, HIGH);
  digitalWrite(GREEN_LED, LOW);
}

void wrongCode() {
  digitalWrite(RED_LED, HIGH);

  delay(2000);

  digitalWrite(RED_LED, LOW);
}
