#include <Keypad.h>

const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {16, 17, 18, 19};
byte colPins[COLS] = {21, 22, 23, 27};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

#define RELAY_PIN 13   

String correctCode = "1234";
String enteredCode = "";

void setup() {
  Serial.begin(115200);
  Serial.println("START");

  pinMode(RELAY_PIN, OUTPUT);

  digitalWrite(RELAY_PIN, HIGH);
}

void loop() {
  char key = keypad.getKey();

  if (key) {
    Serial.println(key);

    if (key == '*') {
      enteredCode = "";
    }
    else if (key == '#') {
      if (enteredCode == correctCode) {
        unlock();
      }
      enteredCode = "";
    }
    else {
      enteredCode += key;
    }
  }
}

void unlock() {
  digitalWrite(RELAY_PIN, LOW);   //ODEMKNI
  delay(3000);
  digitalWrite(RELAY_PIN, HIGH);  //ZAMKNI
}
